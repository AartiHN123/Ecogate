# ─────────────────────────────────────────────────────
#  EcoGate — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Optional ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Anthropic (Hour 8–10 feature) ─────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Database ───────────────────────────────────────────
# DB_PATH=./ecogate.db    (default: ecogate/ root directory)
