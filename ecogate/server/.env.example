# ─── EcoGate Server Configuration ────────────────────────────────────────────
# Copy this file to .env and fill in the keys for the providers you want to use.
# You only need the keys for providers you intend to use.

PORT=3000

# ─── PREREQUISITE: Ollama (local inference) ───────────────────────────────────
# EcoGate uses Ollama for prompt compression AND complexity classification.
# These features are REQUIRED for routing to work correctly.
#
# Install: https://ollama.com/download
# Start:   ollama serve
# Models:  ollama pull qwen2.5:1.5b      # classifier + compressor (lightweight)
#          ollama pull nomic-embed-text   # semantic prompt cache
#          ollama pull gemma4:e4b         # optional: larger compressor model
#
# Ollama endpoint (change if running on a different host/port):
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ─── Provider API Keys ────────────────────────────────────────────────────────
# Set X-EcoGate-Provider: <id> header to select a provider at request time.
# Use id: ollama to route requests to your local Ollama instance (no key needed).

# OpenAI  (id: openai)  https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic  (id: anthropic)  https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini  (id: google)  https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Z.AI / Zhipu GLM  (id: zai)  https://open.bigmodel.cn/usercenter/apikeys
ZAI_API_KEY=

# Groq  (id: groq)  https://console.groq.com/keys
GROQ_API_KEY=

# Mistral AI  (id: mistral)  https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Together AI  (id: together)  https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=

# ─── Complexity Classifier (Ollama — no cloud API needed) ─────────────────────
# The classifier runs locally via Ollama. No API key required.
# It shares the Ollama compressor model by default.
# CLASSIFIER_URL=http://localhost:11434/v1    # Ollama endpoint
# CLASSIFIER_MODEL=qwen2.5:1.5b              # model to use for scoring

# ─── Model Router ─────────────────────────────────────────────────────────────
# Set ECOGATE_RESPECT_MODEL=true to honour the caller's model and skip routing.
# ECOGATE_RESPECT_MODEL=false

# Per-provider tier overrides (uncomment and fill to customise):
# ROUTER_OPENAI_SMALL=gpt-4o-mini
# ROUTER_OPENAI_MEDIUM=gpt-4o
# ROUTER_OPENAI_LARGE=gpt-4-turbo
# ROUTER_ANTHROPIC_SMALL=claude-3-haiku-20240307
# ROUTER_ANTHROPIC_MEDIUM=claude-3-5-sonnet-20241022
# ROUTER_ANTHROPIC_LARGE=claude-3-opus-20240229
# ROUTER_OLLAMA_SMALL=qwen2.5:1.5b
# ROUTER_OLLAMA_MEDIUM=llama3.2
# ROUTER_OLLAMA_LARGE=gemma4:e4b

# ─── Prompt Compressor (local Ollama) ─────────────────────────────────────────
# Prerequisite: ollama pull qwen2.5:1.5b && ollama serve
# COMPRESSOR_ENABLED=true
# COMPRESSOR_URL=http://localhost:11434/v1
# COMPRESSOR_MODEL=qwen2.5:1.5b
# MIN_PROMPT_TOKENS=150          # skip compression for short prompts
# COMPRESSOR_TIMEOUT_MS=500      # fallback to original on timeout

# ─── Prompt Cache ──────────────────────────────────────────────────────────────
# Tier 1: exact SHA-256 match. Tier 2: semantic cosine similarity (Ollama embeddings).
# Prerequisite: ollama pull nomic-embed-text
# CACHE_ENABLED=true
# CACHE_TTL_MS=3600000           # 1 hour  (0 = no expiry)
# CACHE_SEMANTIC_THRESHOLD=0.95  # cosine similarity threshold for semantic hits
# CACHE_EMBEDDING_MODEL=nomic-embed-text
# CACHE_MAX_ENTRIES=5000         # evict oldest entries beyond this count

# ─── Carbon Accounting ────────────────────────────────────────────────────────
# NOTE: Carbon figures displayed by EcoGate are ESTIMATES based on published
# energy-use benchmarks and average grid intensities. They are NOT measured
# values and should be treated as indicative only. Actual emissions will vary
# based on hardware, load, data-centre location, and grid mix at time of use.
