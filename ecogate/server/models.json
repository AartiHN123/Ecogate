{
  "_readme": "Single source of truth for EcoGate providers and models. Keep this in sync with providers.js and router.js. Used by future code as reference.",

  "providers": {

    "openai": {
      "id": "openai",
      "name": "OpenAI",
      "baseURL": "https://api.openai.com/v1",
      "envKey": "OPENAI_API_KEY",
      "website": "https://platform.openai.com",
      "extraHeaders": {},

      "tiers": {
        "small":  "gpt-4o-mini",
        "medium": "gpt-4o",
        "large":  "gpt-4-turbo"
      },

      "classifierModel": "gpt-4o-mini",

      "models": {
        "gpt-4o-mini": {
          "tier": "small",
          "contextWindow": 128000,
          "carbonFactor_gCO2_per_1k_tokens": 0.02,
          "notes": "Default classifier model. Best cost/speed for routing."
        },
        "gpt-4o": {
          "tier": "medium",
          "contextWindow": 128000,
          "carbonFactor_gCO2_per_1k_tokens": 0.15,
          "notes": "Balanced capability and cost."
        },
        "gpt-4-turbo": {
          "tier": "large",
          "contextWindow": 128000,
          "carbonFactor_gCO2_per_1k_tokens": 0.45,
          "notes": "Highest capability baseline."
        },
        "gpt-3.5-turbo": {
          "tier": "small",
          "contextWindow": 16385,
          "carbonFactor_gCO2_per_1k_tokens": 0.02,
          "notes": "Legacy small model."
        }
      }
    },

